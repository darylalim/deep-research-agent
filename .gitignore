# Secrets
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage

# What `/export` writes by default (cli.py: `research-<thread>-<utc>.md`). These are the
# user's reports, not source — and they land in the CWD, which is usually the repo root.
research-*.md

# uv / virtualenv
.venv/

# Local agent state (checkpoints + persistent memory)
.deep_research/

# `langgraph dev` scratch state — the API server's local, pickled-to-disk
# checkpointer/store (the platform-provided persistence graph.py deliberately does
# NOT wire itself). Regenerated on every `langgraph dev`; never source.
.langgraph_api/

# Claude Code: `.claude/settings.json` and `.claude/hooks/` ARE committed (they
# encode project facts, not preferences). Personal overrides are not.
.claude/settings.local.json
