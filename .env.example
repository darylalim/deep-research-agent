# Copy this file to `.env` and fill in your keys, then run the agent.
# The code loads `.env` automatically via python-dotenv.

# --- Model provider (required) ---
# Anthropic API key for Claude (claude-opus-4-8).
ANTHROPIC_API_KEY=

# --- Web search tool (required for real research) ---
# Tavily API key: https://app.tavily.com  (free tier available)
TAVILY_API_KEY=

# --- LangSmith observability (recommended) ---
# Get a key at https://smith.langchain.com — every run becomes traceable.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=deep-research-agent
